// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String    
  provider  Provider
  role      Role 
  Streams  Stream[]
  upvotes   Upvote[]
}

enum Role {
  Streamer
  EndUser
}


model Stream {
  id    String   @id   @default(uuid())
  type  StreamType 
  active   Boolean   @default(true)
  upvote  Upvote[] 
  userId  String 
  user    User    @relation(fields :[userId], references: [id])
  url  String
  extractedId  String
}


model Upvote {
  id    String   @id   @default(uuid())
  userId  String  
  streamId  String
  user  User        @relation(fields: [userId] ,references: [id])
  stream  Stream    @relation(fields: [streamId], references: [id])
  @@unique([userId, streamId ])
}
enum StreamType {
  Spotify 
  Youtube 
}


enum Provider {
  Google 
}
